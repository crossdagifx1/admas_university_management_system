# ATMS frontend environment — copy to `.env` and fill in to connect a live Supabase backend.
# The app runs fully on the bundled seed dataset if these are left unset.
#
# Use the Supabase PROJECT URL and the public ANON key (NOT a Postgres connection
# string and NOT the service_role key — those must never ship in frontend code).
VITE_SUPABASE_URL=https://aqokbotocmyabbftdyvq.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
